# Environment Configuration for Playwright Tests

# Base URLs for different environments
# Uncomment the one you want to use

# Production/Test Environment
# BASE_URL=https://billing.empcloud.com

# Local Development (if you have a local server)
# BASE_URL=http://localhost:3000

# Staging Environment
# BASE_URL=https://staging-billing.empcloud.com

# Development Environment
BASE_URL=https://test-billing.empcloud.com

# Test Configuration
TIMEOUT=60000
HEADLESS=true

# Credentials (use environment-specific values)
ADMIN_EMAIL=admin@acme.com
ADMIN_PASSWORD=Admin@123
